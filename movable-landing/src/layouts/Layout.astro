---
import '../styles/global.css'

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Capture the ground truth behind your dashboards. Movable Voice calls your team to capture the why—delivering operational context that dashboards miss." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Movable Voice" />
		<meta name="keywords" content="operational intelligence, operations management, supply chain, logistics, voice analytics, B2B platform" />

		<meta property="og:title" content="Movable Voice | Operational Intelligence Platform" />
		<meta property="og:description" content="Capture the ground truth behind your dashboards. Movable Voice calls your team to capture the why." />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Movable Voice" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Movable Voice | Operational Intelligence Platform" />
		<meta name="twitter:description" content="Capture the ground truth behind your dashboards." />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,500;0,700;1,700&family=Inter:wght@300;400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-deep-blue text-white min-h-screen overflow-x-hidden">
		<slot />
	</body>
</html>
