---
const footerLinks = [
  { href: "#product", label: "Product" },
  { href: "#solutions", label: "Solutions" },
  { href: "#industries", label: "Industries" },
  { href: "#testimonials", label: "Testimonials" },
  { href: "#", label: "Privacy Policy" },
];
---

<footer class="py-12 px-6 border-t border-white/10">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Logo & Social -->
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center">
          <img
            src="/assets/LOGO/SVGs/Movable_Logo_2026_Primary White.svg"
            alt="Movable"
            class="h-8 w-auto"
          />
        </a>
        <a
          href="https://www.linkedin.com/company/movablevoice/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/50 hover:text-aqua transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>

      <!-- Links -->
      <nav class="flex flex-wrap items-center justify-center gap-6">
        {footerLinks.map(link => (
          <a
            href={link.href}
            class="text-sm text-white/50 hover:text-white transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Copyright -->
      <div class="text-sm text-white/40">
        &copy; 2026 Movable Voice, Inc.
      </div>
    </div>
  </div>
</footer>
