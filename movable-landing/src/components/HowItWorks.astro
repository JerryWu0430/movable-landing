---
const steps = [
  {
    number: "01",
    title: "The Trigger",
    description: "A metric turns red or a manager requests a call.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>`,
  },
  {
    number: "02",
    title: "The Outreach",
    description: "Movable schedules a call with the employee.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`,
  },
  {
    number: "03",
    title: "The Conversation",
    description: "Agent asks contextually specific questions for detail and context.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  },
  {
    number: "04",
    title: "The Synthesis",
    description: "Structured context delivered back to the op centers.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
];
---

<section id="product" class="py-32 px-6 relative">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-heading font-bold mb-4">
        Automated Operational Reach.
      </h2>
      <p class="text-xl text-white/60 max-w-2xl mx-auto">
        A seamless workflow that captures ground truth in minutes, not hours.
      </p>
    </div>

    <!-- Steps Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, index) => (
        <div
          class="group card-glass rounded-2xl p-6 hover:border-tango/30 transition-all duration-300 hover:-translate-y-1"
          style={`animation-delay: ${index * 100}ms;`}
        >
          <!-- Number Badge -->
          <div class="flex items-center justify-between mb-6">
            <span class="text-5xl font-heading font-bold text-tango/20 group-hover:text-tango/40 transition-colors">
              {step.number}
            </span>
            <div class="text-aqua opacity-60 group-hover:opacity-100 transition-opacity" set:html={step.icon} />
          </div>

          <h3 class="text-xl font-heading font-bold mb-3 text-white group-hover:text-tango transition-colors">
            {step.title}
          </h3>

          <p class="text-white/60 text-sm leading-relaxed">
            {step.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Connecting Line (Desktop) -->
    <div class="hidden lg:block absolute top-1/2 left-1/2 -translate-x-1/2 w-3/4 h-0.5 bg-gradient-to-r from-transparent via-aqua/20 to-transparent -z-10"></div>
  </div>
</section>
