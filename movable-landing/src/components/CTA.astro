---
---

<section id="demo" class="py-40 px-6 relative overflow-hidden">
  <!-- Gradient Background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-t from-deep-blue via-transparent to-deep-blue"></div>
    <div class="absolute inset-0 gradient-dark-energy opacity-20"></div>
  </div>

  <!-- Floating Elements -->
  <div class="absolute top-1/4 left-1/4 w-64 h-64 rounded-full bg-aqua/5 blur-3xl animate-float"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-tango/5 blur-3xl animate-float" style="animation-delay: 1.5s;"></div>

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <!-- Heading -->
    <h2 class="text-3xl md:text-5xl lg:text-6xl font-heading font-bold mb-6 leading-tight">
      Stop chasing updates.<br />
      <span class="text-gradient-tango">Start capturing the ground truth.</span>
    </h2>

    <p class="text-xl text-white/60 mb-10 max-w-2xl mx-auto">
      See how Movable Voice can transform your operational intelligence.
    </p>

    <!-- CTA Button -->
    <a
      href="#"
      class="btn-movable btn-tango-filled inline-flex items-center gap-3 px-10 py-5 text-xl"
    >
      <span>Request Demo</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </a>
  </div>
</section>
