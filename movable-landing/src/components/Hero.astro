---
---

<section class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden pt-20">
  <!-- Background Gradient -->
  <div class="absolute inset-0 gradient-dark-energy opacity-30"></div>

  <!-- Floating Elements -->
  <div class="absolute top-1/4 left-10 w-32 h-32 rounded-full bg-aqua/10 blur-3xl animate-float"></div>
  <div class="absolute bottom-1/4 right-10 w-48 h-48 rounded-full bg-tango/10 blur-3xl animate-float" style="animation-delay: 1s;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left Content -->
      <div class="space-y-8">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold leading-[1.1] tracking-tight">
          Capture the
          <span class="text-gradient-tango">Ground Truth</span>
          <br />in Your Operations
        </h1>

        <p class="text-xl md:text-2xl text-white/80 font-body font-light max-w-xl leading-relaxed">
          Movable is the voice AI for <span class="text-aqua font-medium">enterprise context</span>.
        </p>

        <div class="space-y-2">
          <p class="text-lg text-white/60">
            Your metrics tell you <span class="text-white font-medium">what</span> is happening.
          </p>
          <p class="text-lg text-white/60">
            Movable Voice talks to your team for the <span class="text-tango font-medium">why</span>.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a href="#demo" class="btn-movable btn-tango-filled px-8 py-4 text-lg text-center">
            Request Demo
          </a>
        </div>
      </div>

      <!-- Right Content - Ground Truth Card -->
      <div class="relative">
        <div class="card-glass rounded-3xl p-6 space-y-4 max-w-md mx-auto lg:ml-auto">
          <!-- Status Header -->
          <div class="flex items-center justify-between">
            <span class="text-xs font-medium text-aqua uppercase tracking-wider">Infrastructure</span>
            <span class="px-3 py-1 rounded-full bg-tango/20 text-tango text-xs font-medium">At Risk</span>
          </div>

          <div class="text-white/60 text-sm">Site Progress: At Risk</div>
          <div class="text-white/40 text-xs">09:30 — Zone B</div>

          <!-- Ground Truth Box -->
          <div class="bg-deep-blue/50 rounded-xl p-4 border border-aqua/20 mt-4">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-2 h-2 rounded-full bg-aqua animate-pulse"></div>
              <span class="text-xs font-medium text-aqua uppercase tracking-wider">Ground Truth</span>
            </div>
            <p class="text-white/90 text-sm leading-relaxed italic">
              "Electricians waiting on scaffolders to clear Zone B."
            </p>
          </div>

          <div class="flex items-center gap-2 pt-2">
            <svg class="w-4 h-4 text-lime" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-xs text-white/60">Verified • 2 min ago</span>
          </div>
        </div>

        <!-- Decorative Element -->
        <div class="absolute -top-4 -right-4 w-24 h-24 rounded-full border border-aqua/20 animate-pulse-glow"></div>
      </div>
    </div>
  </div>
</section>
