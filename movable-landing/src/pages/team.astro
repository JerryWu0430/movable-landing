---
import Layout from '../layouts/Layout.astro';
import { NavbarWrapper } from '../components/NavbarWrapper';
import Footer from '../components/Footer.astro';

const team = [
  {
    name: "Yan Zhang",
    role: "CEO & Co-Founder",
    image: "/team/team-yan.png",
    linkedin: "https://www.linkedin.com/in/%7Eyan/",
  },
  {
    name: "Marko Stapfner",
    role: "CTO & Co-Founder",
    image: "/team/team-marko.png",
    linkedin: "https://www.linkedin.com/in/marko-stapfner/",
  },
];
---

<Layout title="Team | Movable Voice">
	<NavbarWrapper client:load />
	<main class="pt-32 pb-20 px-6 min-h-screen flex flex-col items-center justify-center">
		<div class="max-w-5xl mx-auto w-full">
			<!-- Team Members -->
			<div class="flex flex-col md:flex-row items-center justify-center md:-space-x-16 mb-8">
				{team.map((member) => (
					<div class="text-center">
						<!-- Image - no circle, just the cutout -->
						<div class="relative w-72 h-72 md:w-96 md:h-96 mx-auto mb-6">
							<img
								src={member.image}
								alt={member.name}
								class="w-full h-full object-contain"
							/>
						</div>

						<h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-2">
							{member.name}
						</h2>
						<p class="text-tango font-medium mb-4">
							{member.role}
						</p>

						<a
							href={member.linkedin}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center justify-center text-white/50 hover:text-aqua transition-colors"
						>
							<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
								<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
							</svg>
						</a>
					</div>
				))}
			</div>

			<!-- Hiring CTA -->
			<div class="text-center">
				<a
					href="https://www.linkedin.com/company/movablevoice/jobs/"
					target="_blank"
					rel="noopener noreferrer"
					class="btn-movable btn-tango-filled inline-flex items-center gap-2 px-8 py-4 text-lg"
				>
					We are hiring!
				</a>
			</div>
		</div>
	</main>
	<Footer />
</Layout>
